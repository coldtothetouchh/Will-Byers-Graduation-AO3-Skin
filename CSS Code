#header h1 sup,
#greeting .icon,
#header .button,
#header .landmark,
#header .logo {
  display: none;
}

#header,
#inner.wrapper {
  margin: 0em 4%;
}

#main,
#inner.wrapper,
.listbox .index,
.work.own,
.thread .even {
  background: #FFF9E6;
}

#outer.wrapper {
  background: #f7e4d2;
  padding-top: 10px;
  background-image: url("https://raw.githubusercontent.com/coldtothetouchh/Will-Byers-Graduation-AO3-Skin/refs/heads/main/Orange-Vintage.jpg");
  background-size: 30.7% auto;
  background-repeat: repeat;
  background-position: center top;
}

#header .heading {
  margin: 20px auto 10px auto;
  border: 2px solid #d48a5a;
  background-color: #f6c6a8;
  border-radius: 0px;
  width: 300px;
  height: 225px;
  display: block;
  position: relative;
  float: none;
}

#header {
  background-color: #fbd9c9;
  border-radius: 20px;
  border: 10px solid #d48a5a;
  box-shadow: 0 0 4px #000;
}

#header .primary {
  box-shadow: none;
  background: none;
  color: #3a1f0d;
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
}

#header .primary li:first-child {
  margin-left: 0em;
}

#header .primary li,
#header .primary li a,
#greeting li,
#greeting li a {
  color: #3a1f0d;
}

#header .heading a {
  color: #bf7a3b;
  font-size: 0;
  padding: 0;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

#header h1.heading a::after {
  content: "";
  display: block;
  width: 300px;
  height: 225px;
  background: url("https://i.postimg.cc/9QKJQB7p/Will-Graduation-GIF.gif") no-repeat center center;
  background-size: contain;
}

#greeting {
  background: none;
  margin-right: auto;
  margin-left: auto;
  color: #3a1f0d;
  padding: 10px 20px;
  clear: both;
  float: none;
  width: 300px;
  font-size: 0.95em;
  display: flex;
  justify-content: center;
}

#greeting li {
  clear: none;
  float: left;
  border-bottom: none;
  border-right: 1px dashed #3a1f0d;
  margin-top: 0;
  padding: 0 8px;
}

#greeting li:last-child {
  border-right: none;
}

#greeting .icon img {
  margin-top: 0.3em;
  border: 2px solid #fff;
}

#greeting .dropdown .menu li {
  margin: 0 0.125em;
}

#greeting .menu {
  width: 16em;
}

#footer .menu a,
#footer .menu {
  color: #3a1f0d;
}

.system .latest h3,
.splash .module h3,
.system .tweets h3 {
  color: #bf7a3b;
}

#footer {
  border: none;
  background: none;
}

.blurb h4 a:link,
#footer h4 {
  color: #bf7a3b;
}

.splash .favorite li:nth-of-type(odd) a:hover,
.splash .favorite li:nth-of-type(odd) a:focus,
a.tag:hover,
a.tag:focus,
#dashboard a:hover,
#dashboard a:focus,
#dashboard .current,
#header .dropdown .menu a:hover,
#header .dropdown .menu a:focus {
  background: #d48a5a;
  color: #fff;
}

#header .actions a:hover,
#header .actions a:focus,
#header .dropdown:hover a,
#header .open a,
#header .dropdown .menu a,
#header .dropdown .menu,
#greeting .dropdown .menu,
#greeting .dropdown .menu a {
  background: #f6c6a8;
  color: #000;
}

#dashboard,
#dashboard.own {
  background: #fbd9c9;
  color: #000;
  border: 2px solid #d48a5a;
  box-shadow: 0 0 2px #000;
}

#header .dropdown .menu,
#greeting .dropdown .menu {
  border: 1px solid #d48a5a;
}

#greeting .current,
#greeting .dropdown:hover li,
#greeting .dropdown:focus li {
  box-shadow: none;
  background: #f6c6a8;
  color: #000;
}

#dashboard ul {
  background: transparent;
  border: none;
}

#dashboard .secondary {
  background-color: #fff;
  box-shadow: none;
}

.splash .module h3,
.splash .news li,
.home .header h2,
li.comment,
dl.meta,
.bookmark .user,
#header .menu li,
#dashboard ul,
#dashboard .secondary,
ul.notes,
.flash,
.notice,
tbody tr,
thead td,
#header #small_login,
fieldset,
form dl,
fieldset dl dl,
fieldset fieldset fieldset,
fieldset fieldset dl dl,
dd.hideme,
form blockquote.userstuff,
form dt,
.actions a:active,
.current,
a.current,
.current a:visited,
.search span.tip,
.listbox,
fieldset fieldset.listbox {
  border-color: #d48a5a;
}

.comment h4.byline,
#main .verbose legend,
.unread,
.child,
.unwrangled,
.unreviewed,
.verbose fieldset,
.draft,
form ul.notes,
#modal,
.ui-sortable li,
.comment_notice,
.kudos_notice,
div.dynamic,
#ui-datepicker-div,
.ui-datepicker table {
  background-color: #e4b89b;
  border-color: #d48a5a;
}

.flash,
.notice {
  background-color: #e4b89b;
  border-color: #000;
}

form .notice,
ul.notes,
.caution {
  background-color: #ffd6b8;
  border-color: #754023;
}

.alert.flash,
.error,
.comment_error,
.kudos_error {
  background: #efd1d1;
  color: #000;
  border-color: #900;
}

h2 {
  font-size: 1.286em;
  line-height: 1;
  margin: 0.5375em 0;
}

.listbox,
.bookmark .user,
.bookmark .user .header,
.reading h4.viewed,
li.relationships a,
.dropdown,
fieldset fieldset.listbox,
fieldset,
form dl,
fieldset dl dl,
fieldset fieldset fieldset,
fieldset fieldset dl dl,
dd.hideme,
form blockquote.userstuff,
.dynamic form fieldset,
.toggled form fieldset,
.toggled form dl,
.secondary .toggled form,
.secondary form,
.required .autocomplete {
  background-color: #f6c6a8;
}

.bookmark .user {
  border-radius: 5px;
}

.filters .submit input {
  color: #FFF;
  background: #d48a5a;
  border: 1px solid #f6c6a8;
  border-radius: 10px;
  box-shadow: 0 0 4px #000;
}

.filters fieldset {
  border-radius: 20px;
}

li.blurb,
.listbox li.blurb,
li.comment,
.statistics .index li:nth-of-type(even),
dl.meta,
dl.index dd,
#ibox_wrapper,
#ibox_content,
textarea:focus,
input:focus,
select:focus {
  background-color: #fbd9c9;
}

textarea,
input,
select,
option,
.toggled form,
.dynamic form,
.autocomplete .dropdown ul,
.autocomplete .dropdown ul li,
.autocomplete input {
  background-color: #fff;
}

li.blurb,
.listbox li.blurb {
  border: 4px solid #d48a5a;
  border-radius: 20px;
  box-shadow: 0 0 4px #000;
}

.blurb .header {
  border-bottom: 2px solid #d48a5a;
}

.bookmark .user .module {
  border: none;
}

.reading h4.viewed,
.bookmark .user {
  box-shadow: none;
}

.reading h4.viewed {
  border: 1px dashed #3a1f0d;
}

.icon {
  border: 2px solid #fff;
}

.comment div.icon {
  border-bottom: none;
}

.workskin .notes,
dl.meta,
.reading h4.viewed,
.bookmark .user,
.comment .posted,
.comment .edited {
  font-size: 90%;
}

#workskin {
  text-align: justify;
}

#workskin h2 {
  font-size: 2.7em;
  color: #bf7a3b;
}

ul.tags li.warnings,
ul.tags li.relationships,
ul.tags li.characters,
ul.tags li.freeforms {
  float: left;
  margin: 0;
  padding: 2px;
}

li.warnings + li.relationships,
li.relationships + li.characters,
li.characters + li.freeforms,
li.warnings + li.characters,
li.warnings + li.freeforms,
li.relationships + li.freeforms {
  clear: left;
}

ul.tags li.warnings:first-child:before {
  content: "Warnings: ";
  color: #3a1f0d;
  font-family: Georgia, serif;
  font-weight: 600;
}

li.warnings + li.relationships:before {
  content: "Relationships: ";
  color: #3a1f0d;
  font-family: Georgia, serif;
  font-weight: 600;
}

li.relationships + li.characters:before {
  content: "Characters: ";
  color: #3a1f0d;
  font-family: Georgia, serif;
  font-weight: 600;
}

li.characters + li.freeforms:before {
  content: "Additional Tags: ";
  color: #3a1f0d;
  font-family: Georgia, serif;
  font-weight: 600;
}

li.warnings + li.characters:before {
  content: "Characters: ";
  color: #3a1f0d;
  font-family: Georgia, serif;
  font-weight: 600;
}

li.warnings + li.freeforms:before {
  content: "Additional Tags: ";
  color: #3a1f0d;
  font-family: Georgia, serif;
  font-weight: 600;
}

li.relationships + li.freeforms:before {
  content: "Additional Tags: ";
  color: #3a1f0d;
  font-family: Georgia, serif;
  font-weight: 600;
}

ul.tags li.relationships a {
  color: #bf7a3b;
}

input[type="submit"],
input[type="reset"],
input[type="button"],
button,
ul.work.navigation.actions li a,
ul.work.navigation.actions li button,
#main ul.work.navigation.actions li a,
#main ul.work.navigation.actions li button,
#main .actions a,
#main .actions button,
#main .actions input[type="submit"],
#workskin ~ ul.work.navigation.actions li a,
body#chapters ul.work.navigation.actions a,
body#chapters ul.work.navigation.actions button,
body#works ul.work.navigation.actions a,
body#works ul.work.navigation.actions button {
  background: #fbd9c9 !important;
  background-color: #fbd9c9 !important;
  color: #3a1f0d !important;
  border: 1px solid #d48a5a !important;
  border-radius: 10px !important;
}

input[type="submit"]:hover,
input[type="reset"]:hover,
input[type="button"]:hover,
button:hover,
ul.work.navigation.actions li a:hover,
ul.work.navigation.actions li button:hover,
#main ul.work.navigation.actions li a:hover,
#main ul.work.navigation.actions li button:hover {
  background: #d48a5a !important;
  background-color: #d48a5a !important;
  color: #fff !important;
  border-color: #bf7a3b !important;
}

p.kudos {
  position: relative;
  padding-top: 120px;
  margin-top: -40px;
  display: block;
  text-align: center;
  background-image: none !important;
}

p.kudos::before {
  content: "";
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 160px;
  height: 160px;
  background: url("https://raw.githubusercontent.com/coldtothetouchh/Will-Byers-Graduation-AO3-Skin/refs/heads/main/Crazy-Together.png") no-repeat center center !important;
  background-size: contain !important;
  display: block !important;
  z-index: 1;
}

p.kudos::after {
  content: none;
}

.kudos_notice .icon,
.kudos_notice img,
#kudos_comment_count img,
p.kudos img,
p.kudos .icon {
  display: none !important;
}

#kudos,
#kudos p,
#kudos .icon,
dd.kudos .icon,
dd.kudos img,
.kudos img,
.kudos .icon {
  background-image: none !important;
}

.kudos_notice {
  position: relative;
  padding-top: 170px;
  text-align: center;
  background-image: none !important;
}

.kudos_notice::before {
  content: "";
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100px;
  height: 100px;
  background: url("https://raw.githubusercontent.com/coldtothetouchh/Will-Byers-Graduation-AO3-Skin/refs/heads/main/Crazy-Together.png") no-repeat center center !important;
  background-size: contain !important;
}
